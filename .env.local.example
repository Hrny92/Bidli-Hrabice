# ─── Sanity CMS ───────────────────────────────────────────────────────────────
# Najdeš na: https://www.sanity.io/manage → projekt → Settings → API
NEXT_PUBLIC_SANITY_PROJECT_ID=fxnzotxb
NEXT_PUBLIC_SANITY_DATASET=production

# Read token – Sanity Manage → API → Tokens → Add API token (role: Viewer)
SANITY_API_READ_TOKEN=

# Secret pro webhook revalidaci (vymysli libovolný řetězec, např. spusť: openssl rand -hex 32)
# Stejnou hodnotu zadáš v Sanity Manage → webhooks → URL: .../api/revalidate?secret=TATO_HODNOTA
SANITY_REVALIDATE_SECRET=

# ─── E-mail (Nodemailer / smtp.seznam.cz) ─────────────────────────────────────
SMTP_HOST=smtp.seznam.cz
SMTP_PORT=465
SMTP_USER=info@hrncirovistudio.cz

# Heslo k e-mailovému účtu SMTP_USER (nastavíš v účtu na seznam.cz)
SMTP_PASS=

SMTP_FROM=info@hrncirovistudio.cz

# Kam přijdou poptávky z formuláře
MAIL_TO=lukas.hrncir@bidli.cz
